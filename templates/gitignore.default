# ai-collab-kit 默认 .gitignore(空目录自举时自动写入;按项目实际增删,改动请知会 Owner)

# 依赖与构建
node_modules/
dist/
build/
__pycache__/
.venv/
venv/

# 大体积媒体与数据(素材/产物不进 git;需要版本化的小资源放专门目录并移除对应行)
media/
output/
render/
cache/
*.mp4
*.mov
*.avi
*.mkv
*.wav
*.mp3
*.flac
*.zip
*.7z

# 密钥与环境(硬升级第 4 类:凭证绝不进 git)
.env
.env.*

# 临时与系统
*.tmp
*.log
.DS_Store
Thumbs.db
